<?xml version="1.0" encoding="utf-8"?>
<!--
  Font family declaration for Manrope.
  Download the TTF from Google Fonts and place in res/font/:
    - manrope_regular.ttf
    - manrope_medium.ttf
    - manrope_bold.ttf
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <font
        android:font="@font/manrope_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/manrope_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />

    <font
        android:font="@font/manrope_medium"
        android:fontStyle="normal"
        android:fontWeight="500"
        app:font="@font/manrope_medium"
        app:fontStyle="normal"
        app:fontWeight="500" />

    <font
        android:font="@font/manrope_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/manrope_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />

</font-family>
