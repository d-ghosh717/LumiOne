<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_track_item"
    android:paddingHorizontal="20dp"
    android:paddingVertical="12dp">

    <!-- Gradient Thumbnail -->
    <ImageView
        android:id="@+id/resultThumbnail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_album_art_placeholder"
        android:scaleType="centerCrop" />

    <!-- Track Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@+id/resultDuration"
        android:layout_toEndOf="@+id/resultThumbnail"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/resultTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F9F5F8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/resultArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:fontFamily="@font/manrope"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Duration -->
    <TextView
        android:id="@+id/resultDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:textColor="#767577"
        android:textSize="12sp"
        android:fontFamily="@font/manrope" />

</RelativeLayout>
